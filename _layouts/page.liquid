---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

{% assign is_project_detail = false %}
{% if page.url contains '/projects/' and page.url != '/projects/' %}
  {% assign is_project_detail = true %}
{% endif %}

<div class="post">
  <header class="post-header{% if is_project_detail %} project-detail-header{% endif %}">
    <h1 class="post-title">{{ page.title }}</h1>
    {% unless is_project_detail %}
      <p class="post-description">{{ page.description }}</p>
    {% endunless %}
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
